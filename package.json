{
  "name": "digitalno-legalno",
  "version": "1.0.0",
  "description": "Digitalno Legalno",
  "scripts": {
    "watch:sass": "sass --watch --quiet-deps -I node_modules scss:./",
    "prefix:css": "postcss --use autoprefixer -b 'last 10 versions' bootstrap.css -o bootstrap.min.css",
    "build:css": "sass --quiet-deps scss/style.scss:style.min.css --style compressed",
    "build:bootstrap": "sass --load-path=node_modules --quiet-deps scss/bootstrap.scss:bootstrap.min.css --style compressed"
  },
  "author": "E-SEO TEAM",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concat": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.1"
  },
  "dependencies": {
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.7",
    "sass": "^1.89.2"
  }
}
